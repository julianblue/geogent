# Shared environment variables for local development.
# Copy to .env and fill in secrets. Never commit .env.

# ----------------------------------------------------------------------------
# Database (PostGIS)
# ----------------------------------------------------------------------------
POSTGRES_USER=geogent
POSTGRES_PASSWORD=geogent
POSTGRES_DB=geogent
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Async SQLAlchemy URL used by the backend.
DATABASE_URL=postgresql+asyncpg://geogent:geogent@db:5432/geogent
# Sync URL used by Alembic migrations.
DATABASE_URL_SYNC=postgresql+psycopg://geogent:geogent@db:5432/geogent

# ----------------------------------------------------------------------------
# LLM providers (set at least one)
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Default chat model used by the agent.
# Examples: claude-opus-4-7 | claude-sonnet-4-6 | gpt-4o
AGENT_MODEL=claude-sonnet-4-6

# ----------------------------------------------------------------------------
# Service URLs (overridden per-service in compose)
# ----------------------------------------------------------------------------
# UI → Backend
NEXT_PUBLIC_API_URL=http://localhost:8000
# UI → Agent (via CopilotKit runtime)
LANGGRAPH_URL=http://localhost:2024
# Agent → Backend
BACKEND_URL=http://localhost:8000

# ----------------------------------------------------------------------------
# Observability (optional)
# ----------------------------------------------------------------------------
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=geogent
