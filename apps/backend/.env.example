APP_NAME=geogent-backend
APP_ENV=development
LOG_LEVEL=INFO

# Async URL for the application.
DATABASE_URL=postgresql+asyncpg://geogent:geogent@localhost:5432/geogent
# Sync URL for Alembic.
DATABASE_URL_SYNC=postgresql+psycopg://geogent:geogent@localhost:5432/geogent

# Comma-separated list of allowed origins (UI dev server, etc.)
CORS_ORIGINS=http://localhost:3000
