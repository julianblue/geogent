ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AGENT_MODEL=claude-sonnet-4-6

# Which architecture to treat as the default for code that needs a single choice.
# Graphs registered in langgraph.json (geogent, geogent-classic) are always
# available independently of this value.
AGENT_ARCHITECTURE=langgraph_react

# Amazon Bedrock (used by the classic-LangChain architecture).
# Credentials are resolved via the standard boto3 chain:
#   AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_SESSION_TOKEN,
#   ~/.aws/credentials, or the instance/task IAM role.
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

BACKEND_URL=http://localhost:8000

LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=geogent
